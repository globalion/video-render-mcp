{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.globalion/video-render-mcp",
  "title": "Video Render MCP",
  "description": "Fireship-style short videos from a topic — Remotion motion graphics, word-timed captions, 1080p.",
  "version": "1.0.0",
  "repository": {
    "url": "https://github.com/globalion/video-render-mcp",
    "source": "github"
  },
  "websiteUrl": "https://video-render.regiq.in",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://video-render.regiq.in/api/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer <API key from https://video-render.regiq.in/dashboard>",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
